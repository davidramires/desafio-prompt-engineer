# LangSmith Configuration (Required)
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=desafio-prompt-engineer

# LLM Provider - Choose ONE:

# Option A: OpenAI (Paid, ~$1-5 for this challenge)
OPENAI_API_KEY=your_openai_api_key_here

# Option B: Google Gemini (Free tier: 15 req/min, 1500 req/day)
# GOOGLE_API_KEY=your_google_api_key_here

# LangSmith Username (for pushing prompts)
LANGSMITH_USERNAME=your_langsmith_username
